<Window x:Class="BibWpf.Dialogs.BuecherEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BibWpf.ViewModels.Dialogs"
        xmlns:m="clr-namespace:BibWpf.Models"
        Title="{Binding Title}"
        Background="#1E1E1E" Foreground="White"
        d:DataContext="{d:DesignInstance Type=vm:BuecherEditDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="540" SizeToContent="Height">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- FORM -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel DataContext="{Binding Entity}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/><RowDefinition/>
                        <RowDefinition/><RowDefinition/><RowDefinition/>
                        <RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Titel*"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4"
                             Text="{Binding Titel, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="ISBN"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4"
                             Text="{Binding Isbn, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, TargetNullValue=''}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="Erscheinungsjahr*"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4"
                             Text="{Binding Erscheinungsjahr, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="Seiten"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,4"
                             Text="{Binding Seiten, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, TargetNullValue=''}"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="Beschreibung"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Margin="0,4" Height="60"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Text="{Binding Beschreibung, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, TargetNullValue=''}"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="Autor*"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" Margin="0,4"
                              ItemsSource="{Binding DataContext.AutorenListe, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="VollstaendigerName"
                              SelectedValue="{Binding AutorId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="Verlag*"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" Margin="0,4"
                              ItemsSource="{Binding DataContext.VerlageListe, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              SelectedValue="{Binding VerlagId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                    <Label Grid.Row="7" Grid.Column="0" Content="Ort"/>
                    <ComboBox Grid.Row="7" Grid.Column="1" Margin="0,4"
                              ItemsSource="{Binding DataContext.OrteListe, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              SelectedValue="{Binding OrtId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, TargetNullValue=''}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- DB-ERROR-BANNER -->
        <Border Grid.Row="1" Background="#5A1D1D" CornerRadius="4" Padding="10,6"
                Margin="0,12,0,8"
                Visibility="{Binding HasDbErrors, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding DbErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Command="{Binding CancelCommand}"
                    MinWidth="90" Margin="0,0,8,0" Padding="8,4"
                    Background="#2D2D30" Foreground="White" BorderThickness="0"/>
            <Button Content="Speichern" Command="{Binding SaveCommand}" IsDefault="True"
                    MinWidth="90" Padding="8,4"
                    Background="#0E639C" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
