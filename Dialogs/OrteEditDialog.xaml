<local:EditDialogBase x:Class="BibWpf.Dialogs.OrteEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BibWpf.Dialogs"
        xmlns:vm="clr-namespace:BibWpf.ViewModels.Dialogs"
        Title="{Binding Title}"
        Background="{StaticResource Brush.Bg}" Foreground="{StaticResource Brush.Text.Primary}"
        d:DataContext="{d:DesignInstance Type=vm:OrteEditDialogViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="780" Height="460" WindowStartupLocation="CenterOwner">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hauptinhalt: Split-Layout -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>   <!-- Linke Spalte: Formular -->
                <ColumnDefinition Width="24"/>    <!-- Spacer / Trenner -->
                <ColumnDefinition Width="*"/>     <!-- Rechte Spalte: Verknüpfungen -->
            </Grid.ColumnDefinitions>

            <!-- Linke Spalte: Formular -->
            <StackPanel Grid.Column="0" DataContext="{Binding Entity}" VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="Name*"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4"
                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="Land"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4"
                             Text="{Binding Land, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                </Grid>
            </StackPanel>

            <!-- Trenner -->
            <Border Grid.Column="1" Width="1" Background="{StaticResource Brush.Border}" HorizontalAlignment="Center" Margin="0,4"/>

            <!-- Rechte Spalte: Verknüpfte Verlage und Autoren (Vertikal gestapelt) -->
            <Grid Grid.Column="2" Margin="4,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Titel Verlage -->
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="1*"/>     <!-- DataGrid Verlage -->
                    <RowDefinition Height="16"/>     <!-- Spacer -->
                    <RowDefinition Height="Auto"/>   <!-- Titel Autoren -->
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="1*"/>     <!-- DataGrid Autoren -->
                </Grid.RowDefinitions>

                <!-- Verlage -->
                <TextBlock Grid.Row="0" Text="Zugeordnete Verlage"
                           Foreground="{StaticResource Brush.Text.Primary}"
                           FontSize="13" FontWeight="SemiBold"/>
                
                <ListBox Grid.Row="2"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding Entity.Verlage}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource Brush.Text.Primary}" FontSize="13" Padding="0,4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Autoren -->
                <TextBlock Grid.Row="4" Text="Zugeordnete Autoren"
                            Foreground="{StaticResource Brush.Text.Primary}"
                            FontSize="13" FontWeight="SemiBold"/>

                <ListBox Grid.Row="6"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding Entity.Autoren}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding VollstaendigerName}" Foreground="{StaticResource Brush.Text.Primary}" FontSize="13" Padding="0,4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- DB-ERROR-BANNER -->
        <Border Grid.Row="1" Background="#5A1D1D" CornerRadius="4" Padding="10,6"
                Margin="0,12,0,8"
                Visibility="{Binding HasDbErrors, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding DbErrorMessage}" Foreground="White" TextWrapping="Wrap"/>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Abbrechen" Command="{Binding CancelCommand}"
                    MinWidth="90" Margin="0,0,8,0" Style="{StaticResource Btn.Secondary}"/>
            <Button Content="Speichern" Command="{Binding SaveCommand}" IsDefault="True"
                    MinWidth="90" Style="{StaticResource Btn.Primary}"/>
        </StackPanel>
    </Grid>
</local:EditDialogBase>
