<Window x:Class="BibWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bibliotheksverwaltung 2026" Height="650" Width="1000"
        Background="#1E1E1E" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR LINKS -->
        <Border Background="#252526" Grid.Column="0">
            <DockPanel Margin="10">
                <TextBlock Text="📚 BibManager" DockPanel.Dock="Top"
                           Foreground="White" FontSize="20" FontWeight="Bold"
                           Margin="10,10,10,30" HorizontalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Top">
                    <Button Content="Bücher"
                            Command="{Binding ShowBuecherCommand}"
                            Margin="0,5" Padding="10"
                            Background="#2D2D30" Foreground="White" BorderThickness="0"/>
                    <Button Content="Autor:innen"
                            Command="{Binding ShowAutorenCommand}"
                            Margin="0,5" Padding="10"
                            Background="#2D2D30" Foreground="White" BorderThickness="0"/>
                    <Button Content="Verlage"
                            Command="{Binding ShowVerlageCommand}"
                            Margin="0,5" Padding="10"
                            Background="#2D2D30" Foreground="White" BorderThickness="0"/>
                    <Button Content="Orte"
                            Command="{Binding ShowOrteCommand}"
                            Margin="0,5" Padding="10"
                            Background="#2D2D30" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <TextBlock Text="Status: Aktiv" DockPanel.Dock="Bottom"
                           Foreground="#6A9955" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,10"/>
            </DockPanel>
        </Border>

        <!-- HAUPTINHALT RECHTS: ContentControl mit DataTemplates aus App.xaml -->
        <ContentControl Grid.Column="1" Margin="20"
                        Content="{Binding CurrentView}"/>
    </Grid>
</Window>
