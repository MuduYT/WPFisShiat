<Window x:Class="BibWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BibManager — Bibliotheksverwaltung"
        Height="700" Width="1100"
        MinHeight="560" MinWidth="860"
        Background="{StaticResource Brush.Bg.App}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════ SIDEBAR ═══════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.Bg.Sidebar}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="12,20,12,20">

                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="4,0,4,32">
                    <TextBlock Text="BibManager"
                               Foreground="{StaticResource Brush.Text.Primary}"
                               FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Bibliotheksverwaltung"
                               Foreground="{StaticResource Brush.Text.Muted}"
                               FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Trennlinie -->
                <Border DockPanel.Dock="Top"
                        Height="1" Margin="0,0,0,16"
                        Background="{StaticResource Brush.Border.Subtle}"/>

                <!-- Nav-Label -->
                <TextBlock DockPanel.Dock="Top"
                           Text="BEREICHE"
                           Foreground="{StaticResource Brush.Text.Muted}"
                           FontSize="10" FontWeight="SemiBold"
                           Margin="16,0,0,8"/>

                <!-- Nav-Buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,0">
                    <Button Content="📚  Bücher"
                            Command="{Binding ShowBuecherCommand}"
                            Style="{StaticResource Btn.Nav}"
                            Margin="0,2"/>
                    <Button Content="✍  Autor:innen"
                            Command="{Binding ShowAutorenCommand}"
                            Style="{StaticResource Btn.Nav}"
                            Margin="0,2"/>
                    <Button Content="🏢  Verlage"
                            Command="{Binding ShowVerlageCommand}"
                            Style="{StaticResource Btn.Nav}"
                            Margin="0,2"/>
                    <Button Content="📍  Orte"
                            Command="{Binding ShowOrteCommand}"
                            Style="{StaticResource Btn.Nav}"
                            Margin="0,2"/>
                    <Button Content="⚙  Einstellungen"
                            Command="{Binding ShowSettingsCommand}"
                            Style="{StaticResource Btn.Nav}"
                            Margin="0,2"/>
                </StackPanel>

                <!-- Status-Indikator unten -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="16,0">
                    <Ellipse Width="7" Height="7" Fill="#22C55E"
                             VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock Text="Verbunden"
                               Foreground="{StaticResource Brush.Text.Muted}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══════════════════ HAUPTINHALT ═══════════════════ -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Margin="28,28,28,20"/>
    </Grid>
</Window>
