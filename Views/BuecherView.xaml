<UserControl x:Class="BibWpf.Views.BuecherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="860">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Seitenheader -->
            <RowDefinition Height="16"/>     <!-- Spacer -->
            <RowDefinition Height="*"/>      <!-- Tabelle -->
            <RowDefinition Height="Auto"/>   <!-- Fehlermeldung -->
        </Grid.RowDefinitions>

        <!-- ── Seitenheader ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Titel + Untertitel -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}"
                           Foreground="{StaticResource Brush.Text.Primary}"
                           FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Alle Bücher verwalten"
                           Foreground="{StaticResource Brush.Text.Muted}"
                           FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Aktionsbuttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                <Button Content="＋  Neu"
                        Command="{Binding AddCommand}"
                        Style="{StaticResource Btn.Primary}"
                        Margin="0,0,8,0" MinWidth="88"/>
                <Button Content="✎  Bearbeiten"
                        Command="{Binding EditCommand}"
                        Style="{StaticResource Btn.Secondary}"
                        Margin="0,0,8,0" MinWidth="110"/>
                <Button Content="✕  Löschen"
                        Command="{Binding DeleteCommand}"
                        Style="{StaticResource Btn.Danger}"
                        MinWidth="88"/>
            </StackPanel>
        </Grid>

        <!-- ── Tabelle ── -->
        <DataGrid Grid.Row="2"
                  Style="{StaticResource AppDataGrid}"
                  ItemsSource="{Binding Buecher}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"       Binding="{Binding Id}"               Width="0.5*" MinWidth="45"/>
                <DataGridTextColumn Header="Titel"   Binding="{Binding Titel}"            Width="3.5*" MinWidth="160"/>
                <DataGridTextColumn Header="Autor"   Binding="{Binding Autor.VollstaendigerName}" Width="2*" MinWidth="120"/>
                <DataGridTextColumn Header="Verlag"  Binding="{Binding Verlag.Name}"      Width="2*" MinWidth="120"/>
                <DataGridTextColumn Header="Jahr"    Binding="{Binding Erscheinungsjahr}" Width="1*" MinWidth="60"/>
                <DataGridTextColumn Header="ISBN"    Binding="{Binding Isbn}"             Width="2*" MinWidth="110"/>
                <DataGridTextColumn Header="Seiten"  Binding="{Binding Seiten}"           Width="1*" MinWidth="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ── Fehlermeldung ── -->
        <Border Grid.Row="3"
                Background="#1C0A0A"
                BorderBrush="#7F1D1D" BorderThickness="0,1,0,0"
                Padding="12,8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#FCA5A5" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>
