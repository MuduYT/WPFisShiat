<UserControl x:Class="BibWpf.Views.VerlageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}"
                   Foreground="White" FontSize="24" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Verlage}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#252526"
                  RowBackground="#1E1E1E"
                  Foreground="White"
                  BorderBrush="#3F3F46"
                  Background="#1E1E1E">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"           Binding="{Binding Id}"              Width="60"/>
                <DataGridTextColumn Header="Name"         Binding="{Binding Name}"            Width="*"/>
                <DataGridTextColumn Header="Gegründet"    Binding="{Binding Gruendungsjahr}"  Width="100"/>
                <DataGridTextColumn Header="Sitz (Ort)"   Binding="{Binding Ort.Name}"        Width="180"/>
                <DataGridTextColumn Header="# Bücher"     Binding="{Binding Buecher.Count}"   Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="#F48771"
                   FontSize="12" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
