<Application x:Class="BibWpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BibWpf.ViewModels"
             xmlns:v="clr-namespace:BibWpf.Views"
             xmlns:conv="clr-namespace:BibWpf.Converters">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ═══════════════════════════════════════════════════════
                 FARB-PALETTE  (dunkelblau / schwarz / hellgrau)
                 ═══════════════════════════════════════════════════════ -->
            <Color x:Key="Col.Bg.App">#0B0F1A</Color>
            <Color x:Key="Col.Bg.Sidebar">#0E1525</Color>
            <Color x:Key="Col.Bg.Content">#0B0F1A</Color>
            <Color x:Key="Col.Bg.Card">#111827</Color>
            <Color x:Key="Col.Bg.Row">#111827</Color>
            <Color x:Key="Col.Bg.RowAlt">#0E1525</Color>
            <Color x:Key="Col.Bg.Header">#0B1020</Color>
            <Color x:Key="Col.Bg.Selected">#1A3A6E</Color>
            <Color x:Key="Col.Bg.Hover">#1A2540</Color>

            <Color x:Key="Col.Accent.Blue">#2563EB</Color>
            <Color x:Key="Col.Accent.BlueDark">#1D4ED8</Color>
            <Color x:Key="Col.Accent.BlueLight">#3B82F6</Color>

            <Color x:Key="Col.Border.Default">#1E2D4A</Color>
            <Color x:Key="Col.Border.Subtle">#162035</Color>
            <Color x:Key="Col.Border.Focus">#3B82F6</Color>

            <Color x:Key="Col.Text.Primary">#F1F5F9</Color>
            <Color x:Key="Col.Text.Secondary">#94A3B8</Color>
            <Color x:Key="Col.Text.Muted">#475569</Color>
            <Color x:Key="Col.Text.Accent">#60A5FA</Color>

            <Color x:Key="Col.Btn.Edit">#1E293B</Color>
            <Color x:Key="Col.Btn.EditHover">#273449</Color>
            <Color x:Key="Col.Btn.Delete">#7F1D1D</Color>
            <Color x:Key="Col.Btn.DeleteHover">#991B1B</Color>

            <!-- SolidColorBrushes -->
            <SolidColorBrush x:Key="Brush.Bg.App"       Color="{StaticResource Col.Bg.App}"/>
            <SolidColorBrush x:Key="Brush.Bg"           Color="{StaticResource Col.Bg.App}"/>
            <SolidColorBrush x:Key="Brush.Bg.Sidebar"   Color="{StaticResource Col.Bg.Sidebar}"/>
            <SolidColorBrush x:Key="Brush.Bg.Card"      Color="{StaticResource Col.Bg.Card}"/>
            <SolidColorBrush x:Key="Brush.Bg.Header"    Color="{StaticResource Col.Bg.Header}"/>
            <SolidColorBrush x:Key="Brush.Bg.Row"       Color="{StaticResource Col.Bg.Row}"/>
            <SolidColorBrush x:Key="Brush.Bg.RowAlt"    Color="{StaticResource Col.Bg.RowAlt}"/>
            <SolidColorBrush x:Key="Brush.Bg.Selected"  Color="{StaticResource Col.Bg.Selected}"/>
            <SolidColorBrush x:Key="Brush.Bg.Hover"     Color="{StaticResource Col.Bg.Hover}"/>
            <SolidColorBrush x:Key="Brush.Accent.Blue"  Color="{StaticResource Col.Accent.Blue}"/>
            <SolidColorBrush x:Key="Brush.Border"       Color="{StaticResource Col.Border.Default}"/>
            <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Col.Border.Subtle}"/>
            <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Col.Text.Primary}"/>
            <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Col.Text.Secondary}"/>
            <SolidColorBrush x:Key="Brush.Text.Muted"   Color="{StaticResource Col.Text.Muted}"/>
            <SolidColorBrush x:Key="Brush.Text.Accent"  Color="{StaticResource Col.Text.Accent}"/>

            <!-- Converter -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:StringToVisibilityConverter x:Key="StringToVisibility"/>

            <!-- ═══════════════════════════════════════════════════════
                 SCROLLBAR
                 ═══════════════════════════════════════════════════════ -->
            <Style x:Key="ScrollBarThumb" TargetType="Thumb">
                <Setter Property="Background" Value="#1E3A5F"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2563EB"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="#0B0F1A"/>
                <Setter Property="Width" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="1"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══════════════════════════════════════════════════════
                 DATAGRID — globaler Stil
                 ═══════════════════════════════════════════════════════ -->
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"   Value="{StaticResource Brush.Bg.Header}"/>
                <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Secondary}"/>
                <Setter Property="FontSize"     Value="11"/>
                <Setter Property="FontWeight"   Value="SemiBold"/>
                <Setter Property="Padding"      Value="12,10"/>
                <Setter Property="BorderBrush"  Value="{StaticResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="{TemplateBinding FontWeight}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="Background"        Value="{StaticResource Brush.Bg.Row}"/>
                <Setter Property="Foreground"        Value="{StaticResource Brush.Text.Primary}"/>
                <Setter Property="MinHeight"         Value="42"/>
                <Setter Property="BorderThickness"   Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.Bg.Selected}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.Bg.Hover}"/>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsSelected"  Value="True"/>
                            <Condition Property="IsMouseOver" Value="True"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource Brush.Bg.Selected}"/>
                    </MultiTrigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="Padding"         Value="12,0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background"      Value="Transparent"/>
                <Setter Property="Foreground"      Value="{StaticResource Brush.Text.Primary}"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="Foreground"  Value="{StaticResource Brush.Text.Primary}"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="AppDataGrid" TargetType="DataGrid">
                <Setter Property="Background"           Value="{StaticResource Brush.Bg.Card}"/>
                <Setter Property="RowBackground"        Value="{StaticResource Brush.Bg.Row}"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource Brush.Bg.RowAlt}"/>
                <Setter Property="Foreground"           Value="{StaticResource Brush.Text.Primary}"/>
                <Setter Property="BorderBrush"          Value="{StaticResource Brush.Border}"/>
                <Setter Property="BorderThickness"      Value="1"/>
                <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.Border.Subtle}"/>
                <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
                <Setter Property="SelectionMode"        Value="Single"/>
                <Setter Property="SelectionUnit"        Value="FullRow"/>
                <Setter Property="AutoGenerateColumns"  Value="False"/>
                <Setter Property="IsReadOnly"           Value="True"/>
                <Setter Property="CanUserAddRows"       Value="False"/>
                <Setter Property="CanUserDeleteRows"    Value="False"/>
                <Setter Property="HeadersVisibility"    Value="Column"/>
                <Setter Property="RowHeaderWidth"       Value="0"/>
                <Setter Property="ColumnHeaderHeight"   Value="40"/>
                <Setter Property="FontSize"             Value="13"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            </Style>

            <!-- ═══════════════════════════════════════════════════════
                 BUTTONS
                 ═══════════════════════════════════════════════════════ -->

            <!-- Primär (Neu) -->
            <Style x:Key="Btn.Primary" TargetType="Button">
                <Setter Property="Background"    Value="{StaticResource Brush.Accent.Blue}"/>
                <Setter Property="Foreground"    Value="#FFFFFF"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"       Value="16,8"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="FontWeight"    Value="SemiBold"/>
                <Setter Property="Cursor"        Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Sekundär (Bearbeiten) -->
            <Style x:Key="Btn.Secondary" TargetType="Button">
                <Setter Property="Background"    Value="#1E293B"/>
                <Setter Property="Foreground"    Value="{StaticResource Brush.Text.Primary}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush"   Value="{StaticResource Brush.Border}"/>
                <Setter Property="Padding"       Value="16,8"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="FontWeight"    Value="SemiBold"/>
                <Setter Property="Cursor"        Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#273449"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A2540"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#0F172A"/>
                                    <Setter Property="Foreground" Value="#334155"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#1E293B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Gefährlich (Löschen) -->
            <Style x:Key="Btn.Danger" TargetType="Button">
                <Setter Property="Background"    Value="#7F1D1D"/>
                <Setter Property="Foreground"    Value="#FCA5A5"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"       Value="16,8"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="FontWeight"    Value="SemiBold"/>
                <Setter Property="Cursor"        Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#991B1B"/>
                                    <Setter Property="Foreground" Value="#FECACA"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#7F1D1D"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Sidebar-Nav-Button -->
            <Style x:Key="Btn.Nav" TargetType="Button">
                <Setter Property="Background"    Value="Transparent"/>
                <Setter Property="Foreground"    Value="{StaticResource Brush.Text.Secondary}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"       Value="16,11"/>
                <Setter Property="FontSize"      Value="13"/>
                <Setter Property="FontWeight"    Value="Medium"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor"        Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#162035"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1A2540"/>
                                    <Setter Property="Foreground" Value="#60A5FA"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Globaler Standard-Stil für Label in Dialogen -->
            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,4"/>
            </Style>

            <!-- Globaler Standard-Stil für TextBox in Dialogen -->
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource Brush.Bg.Card}"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="CaretBrush" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Resources>
                    <!-- Ändert den standardmäßigen CornerRadius des inneren Rahmens -->
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Style.Resources>
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent.Blue}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Globaler Standard-Stil für ComboBox in Dialogen -->
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource Brush.Bg.Card}"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent.Blue}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Globaler Standard-Stil für ComboBoxItem (Dark Theme Lesbarkeit) -->
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="{StaticResource Brush.Bg.Card}"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="13"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.Bg.Hover}"/>
                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{StaticResource Brush.Bg.Selected}"/>
                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ═══════════════════════════════════════════════════════
                 DataTemplates: ViewModel → View
                 ═══════════════════════════════════════════════════════ -->
            <DataTemplate DataType="{x:Type vm:BuecherViewModel}">
                <v:BuecherView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AutorenViewModel}">
                <v:AutorenView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VerlageViewModel}">
                <v:VerlageView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OrteViewModel}">
                <v:OrteView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <v:SettingsView/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
